{
  "locale": "it",
  "logoPosition": "right",
  "pages": [
    {
      "name": "page1",
      "elements": [
        {
          "type": "dropdown",
          "name": "tipo",
          "title": "Tipo di Tassa",
          "hideNumber": true,
          "isRequired": true,
          "choices": [
            {
              "value": "Rilascio",
              "text": "Rilascio"
            }
          ]
        },
        {
          "type": "text",
          "name": "anno_riferimento",
          "title": "Anno di Riferimento",
          "isRequired": true,
          "minLength": 4,
          "maxLength": 4,
          "validators": [
            {
              "type": "numeric",
              "text": "Anno di riferimento errato",
              "minValue": 1900,
              "maxValue": 2100
            }
          ]
        },
        {
          "type": "dropdown",
          "name": "attivita",
          "title": "Attività",
          "hideNumber": true,
          "isRequired": true,
          "choices": [
            {
              "value": "industriali-commerciali",
              "text": "Attività industriali o commerciali"
            },
            {
              "value": "professioni",
              "text": "Professioni"
            },
            {
              "value": "arti-mestieri",
              "text": "Arti e mestieri"
            }
          ]
        },
        {
          "type": "text",
          "name": "nome",
          "title": "Nome",
          "hideNumber": true,
          "isRequired": true
        },
        {
          "type": "text",
          "name": "cognome",
          "title": "Cognome",
          "hideNumber": true,
          "isRequired": true
        },
        {
          "type": "text",
          "name": "identificativo",
          "title": "Codice fiscale",
          "hideNumber": true,
          "isRequired": true,
          "validators": [
            {
              "type": "regex",
              "text": "Codice fiscale errato",
              "regex": "^[0-9]{11}$|^[A-Za-z]{6}[0-9LMNPQRSTUV]{2}[A-Za-z]{1}[0-9LMNPQRSTUV]{2}[A-Za-z]{1}[0-9LMNPQRSTUV]{3}[A-Za-z]{1}$"
            },
            {
              "type": "expression",
              "text": "Codice fiscale non corrispondente ai dati inseriti",
              "expression": "CFValidator({identificativo}, {nome}, {cognome})"
            }
          ],
          "uppercase": true
        },
        {
          "type": "text",
          "name": "indirizzo",
          "title": "Indirizzo",
          "hideNumber": true,
          "isRequired": true
        }
      ]
    }
  ]
}
